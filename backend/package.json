{
  "name": "shiftsure-backend",
  "version": "1.0.0",
  "description": "ShiftSure backend — Express + Firebase Admin SDK",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --forceExit"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
